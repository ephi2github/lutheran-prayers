{
  "name": "lutheran-prayers",
  "version": "1.1.1",
  "description": "Offline-first, bilingual (English/Amharic) corpus of 411 confessional Lutheran prayers with an Ethiopian-calendar-anchored prayer-of-the-day scheduler.",
  "keywords": [
    "lutheran",
    "prayers",
    "liturgy",
    "amharic",
    "ethiopian-calendar",
    "bahire-hasab",
    "kenat",
    "bilingual",
    "prayer-of-the-day",
    "confessional-lutheran",
    "offline",
    "devotional"
  ],
  "author": "Ephrem K. Getachew <ephigetachek@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ephi2github/lutheran-prayers.git"
  },
  "bugs": {
    "url": "https://github.com/ephi2github/lutheran-prayers/issues"
  },
  "homepage": "https://github.com/ephi2github/lutheran-prayers#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "validate:data": "tsx scripts/validate-data.ts",
    "build:data": "tsx scripts/build-data.ts",
    "build": "tsup",
    "prepack": "tsup",
    "test": "tsup && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "packageManager": "pnpm@9.15.9",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "kenat": "^3.2.0"
  }
}
